generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  OPEN
  DONE
  CANCELED
}

enum IdeaStatus {
  RAW
  CLARIFIED
  SELECTED
  PROTOTYPING
  BUILT
  PAUSED
  REJECTED
}

enum ReminderMode {
  INDIVIDUAL
  DIGEST
}

enum RecurrenceRule {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum CaptureKind {
  IDEA
  TASK
  REFLECTION
  NOTE
  NOISE
}

enum GroupMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum GroupMemberStatus {
  ACTIVE
  LEFT
  KICKED
}

enum TaskAssigneeStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum GroupActivityType {
  TASK_CREATED
  TASK_UPDATED
  TASK_COMPLETED
  TASK_REOPENED
  TASK_ARCHIVED
  TASK_ASSIGNED
  TASK_UNASSIGNED
  ASSIGNMENT_ACCEPTED
  ASSIGNMENT_DECLINED
  TASK_BLOCKED
  TASK_UNBLOCKED
  TASK_HANDED_OFF
}

model User {
  id         String   @id @default(uuid())
  telegramId String   @unique
  username   String?
  firstName  String?
  lastName   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  settings              UserSettings?
  ideas                 Idea[]
  tasks                 Task[]
  notes                 Note[]
  reflections           Reflection[]
  pendingCaptures       PendingCapture[]
  pendingNoteMerges     PendingNoteMerge[]
  pendingItemEdits      PendingItemEdit[]
  pendingBulkActions    PendingBulkAction[]
  pendingSearches       PendingSearch[]
  pendingGmailOAuth     PendingGmailOAuth[]
  gmailConnection       GmailConnection?
  gmailSummaries        GmailMessageSummary[]
  pendingCalendarOAuth  PendingCalendarOAuth[]
  calendarConnection    CalendarConnection?
  pendingImageCaptures  PendingImageCapture[]
  pendingImageUploads   PendingImageUpload[]
  storedImages          StoredImage[]
  pendingExpenses       PendingExpense[]
  expenses              Expense[]
  pendingMicrosoftOAuth PendingMicrosoftOAuth[]
  microsoftConnection   MicrosoftConnection?
  reminderHistory       ReminderDelivery[]
  auditLogs             AuditLog[]
  groupWorkspace        GroupWorkspace? @relation("GroupWorkspaceOwner")
}

model GroupWorkspace {
  id             String   @id @default(uuid())
  ownerUserId    String   @unique
  telegramChatId String   @unique
  title          String
  username       String?
  isActive       Boolean  @default(true)
  botStatus      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ownerUser User              @relation("GroupWorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members   GroupMembership[]
  activity  GroupActivity[]

  @@index([isActive, updatedAt])
}

model GroupActivity {
  id              String            @id @default(uuid())
  workspaceId     String
  actorTelegramId String
  actorName        String
  type             GroupActivityType
  taskPublicId     String?
  taskTitle        String?
  summary          String
  metadata         Json?
  createdAt        DateTime          @default(now())

  workspace GroupWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, type, createdAt])
}

model GroupMembership {
  id           String            @id @default(uuid())
  workspaceId  String
  telegramId   String
  username     String?
  firstName    String?
  lastName     String?
  role         GroupMemberRole   @default(MEMBER)
  status       GroupMemberStatus @default(ACTIVE)
  lastSeenAt   DateTime           @default(now())
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  workspace GroupWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, telegramId])
  @@index([telegramId, status])
  @@index([workspaceId, role])
}

model UserSettings {
  id                      String       @id @default(uuid())
  userId                  String       @unique
  reminderIntervalMinutes Int          @default(180)
  timezone                String       @default("Asia/Singapore")
  quietHoursStart         String?      @default("22:00")
  quietHoursEnd           String?      @default("08:00")
  maxRemindersPerDay      Int          @default(200)
  dueNudgeMinutes         Int          @default(3)
  reminderMode            ReminderMode @default(INDIVIDUAL)
  reminderChatId          String?
  expenseCurrency         String       @default("SGD")
  ocrLanguages            String       @default("eng")
  directNudgesEnabled     Boolean      @default(false)
  calendarAutoSync        Boolean      @default(false)
  excelAutoSync           Boolean      @default(false)
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Idea {
  id             String     @id @default(uuid())
  userId         String
  publicId       String
  title          String
  concept        String
  problem        String?
  targetUser     String?
  type           String?
  status         IdeaStatus @default(RAW)
  tags           String[]
  sourceText     String
  embedding      Json?
  scores         Json?
  marketNotes    String?
  dos            String[]
  donts          String[]
  pinnedAt       DateTime?
  archivedAt     DateTime?
  archivedReason String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, publicId])
  @@index([userId, createdAt])
  @@index([userId, pinnedAt])
  @@index([userId, archivedAt])
}

model Task {
  id                      String          @id @default(uuid())
  userId                  String
  publicId                String
  title                   String
  description             String?
  status                  TaskStatus      @default(OPEN)
  sourceText              String
  dueAt                   DateTime?
  timezone                String?
  reminderIntervalMinutes Int?
  nextReminderAt          DateTime?
  snoozedUntil            DateTime?
  completedAt             DateTime?
  lastRemindedAt          DateTime?
  reminderCount           Int             @default(0)
  embedding               Json?
  calendarUrl             String?
  calendarEventId         String?
  calendarEventUrl        String?
  calendarSyncedAt        DateTime?
  assignedTelegramId      String?
  assignedUsername        String?
  assignedDisplayName     String?
  recurrenceRule          RecurrenceRule?
  recurrenceIntervalDays  Int?
  recurrenceDayOfMonth    Int?
  pinnedAt                DateTime?
  archivedAt              DateTime?
  archivedReason          String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminderHistory ReminderDelivery[]
  assignees       TaskAssignee[]

  @@unique([userId, publicId])
  @@index([status, nextReminderAt])
  @@index([userId, createdAt])
  @@index([userId, assignedUsername])
  @@index([recurrenceRule, nextReminderAt])
  @@index([userId, pinnedAt])
  @@index([userId, archivedAt])
}

model TaskAssignee {
  id            String             @id @default(uuid())
  taskId        String
  normalizedKey String
  telegramId    String?
  username      String?
  displayName   String?
  status        TaskAssigneeStatus @default(PENDING)
  statusReason  String?
  respondedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, normalizedKey])
  @@index([telegramId, status])
  @@index([username])
  @@index([taskId, status])
}

model Note {
  id               String    @id @default(uuid())
  userId           String
  publicId         String
  title            String
  body             String
  summary          String
  sourceText       String
  tags             String[]
  embedding        Json?
  pinnedAt         DateTime?
  archivedAt       DateTime?
  archivedReason   String?
  mergedIntoNoteId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  mergedIntoNote    Note?  @relation("NoteMerge", fields: [mergedIntoNoteId], references: [id], onDelete: SetNull)
  mergedSourceNotes Note[] @relation("NoteMerge")

  @@unique([userId, publicId])
  @@index([userId, createdAt])
  @@index([userId, pinnedAt])
  @@index([userId, archivedAt])
  @@index([userId, mergedIntoNoteId])
}

model Reflection {
  id              String    @id @default(uuid())
  userId          String
  publicId        String
  sourceText      String
  situation       String
  balancedView    String
  immediateAction String
  keepInMind      String
  risks           String[]
  embedding       Json?
  pinnedAt        DateTime?
  archivedAt      DateTime?
  archivedReason  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, publicId])
  @@index([userId, createdAt])
  @@index([userId, pinnedAt])
  @@index([userId, archivedAt])
}

model PendingCapture {
  id         String      @id @default(uuid())
  userId     String
  kind       CaptureKind
  sourceText String
  payload    Json
  expiresAt  DateTime
  createdAt  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PendingNoteMerge {
  id            String   @id @default(uuid())
  userId        String
  sourceNoteIds String[]
  preview       Json
  attemptCount  Int      @default(1)
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PendingItemEdit {
  id            String   @id @default(uuid())
  userId        String
  itemKind      String
  itemId        String
  itemPublicId  String
  editField     String   @default("title")
  previousTitle String
  previousValue String?
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PendingBulkAction {
  id                    String   @id @default(uuid())
  userId                String
  action                String
  itemKind              String
  itemIds               String[]
  requestedByTelegramId String
  expiresAt             DateTime
  createdAt             DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PendingSearch {
  id          String   @id @default(uuid())
  userId      String
  query       String
  kinds       String[]
  label       String?
  includeDone Boolean  @default(false)
  doneOnly    Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PendingGmailOAuth {
  id        String   @id @default(uuid())
  userId    String
  state     String   @unique
  chatId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model GmailConnection {
  id                   String    @id @default(uuid())
  userId               String    @unique
  gmailEmail           String?
  accessToken          String?
  refreshToken         String
  accessTokenExpiresAt DateTime?
  scanEnabled          Boolean   @default(true)
  scanHourLocal        Int       @default(8)
  summaryChatId        String?
  lastScanAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([scanEnabled, lastScanAt])
}

model GmailMessageSummary {
  id               String    @id @default(uuid())
  userId           String
  gmailMessageId   String
  gmailThreadId    String?
  from             String
  subject          String
  snippet          String
  summary          String
  important        Boolean   @default(false)
  importanceReason String?
  suggestedAction  String?
  receivedAt       DateTime?
  reminderTaskId   String?
  scannedAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gmailMessageId])
  @@index([userId, scannedAt])
  @@index([userId, important])
}

model PendingCalendarOAuth {
  id             String   @id @default(uuid())
  userId         String
  state          String   @unique
  chatId         String
  taskId         String?
  enableAutoSync Boolean  @default(false)
  returnTo       String?
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model CalendarConnection {
  id                   String    @id @default(uuid())
  userId               String    @unique
  calendarEmail        String?
  accessToken          String?
  refreshToken         String
  accessTokenExpiresAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PendingImageCapture {
  id               String   @id @default(uuid())
  userId           String
  extractedText    String
  caption          String?
  telegramFileId   String?
  telegramUniqueId String?
  confidence       Float?
  awaitingAction   String?
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, awaitingAction, expiresAt])
}

model PendingImageUpload {
  id               String   @id @default(uuid())
  userId           String
  telegramFileId   String
  telegramUniqueId String?
  mediaKind        String
  mimeType         String?
  fileName         String?
  caption          String?
  fileSize         Int?
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model StoredImage {
  id               String   @id @default(uuid())
  userId           String
  publicId         String
  telegramFileId   String
  telegramUniqueId String?
  mediaKind        String
  mimeType         String?
  fileName         String?
  caption          String?
  ocrText          String?
  ocrConfidence    Float?
  pinnedAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, publicId])
  @@index([userId, pinnedAt])
  @@index([userId, createdAt])
  @@index([userId, telegramUniqueId])
}

model PendingExpense {
  id                  String   @id @default(uuid())
  userId              String
  sourceText          String
  sourceType          String
  merchant            String?
  transactionAt       DateTime
  category            String?
  description         String?
  subtotal            Decimal? @db.Decimal(12, 2)
  tax                 Decimal? @db.Decimal(12, 2)
  discount            Decimal? @db.Decimal(12, 2)
  total               Decimal  @db.Decimal(12, 2)
  currency            String   @default("SGD")
  paymentMethod       String?
  receiptFileUniqueId String?
  ocrConfidence       Float?
  notes               String?
  awaitingEdit        Boolean  @default(false)
  expiresAt           DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, awaitingEdit, expiresAt])
}

model Expense {
  id                  String    @id @default(uuid())
  userId              String
  publicId            String
  merchant            String?
  transactionAt       DateTime
  category            String?
  description         String?
  subtotal            Decimal?  @db.Decimal(12, 2)
  tax                 Decimal?  @db.Decimal(12, 2)
  discount            Decimal?  @db.Decimal(12, 2)
  total               Decimal   @db.Decimal(12, 2)
  currency            String    @default("SGD")
  paymentMethod       String?
  sourceType          String
  receiptFileUniqueId String?
  receiptContentHash  String?
  rawText             String
  ocrConfidence       Float?
  notes               String?
  excelSyncedAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, publicId])
  @@unique([userId, receiptContentHash])
  @@index([userId, transactionAt])
  @@index([userId, createdAt])
  @@index([userId, excelSyncedAt])
}

model PendingMicrosoftOAuth {
  id             String   @id @default(uuid())
  userId         String
  state          String   @unique
  chatId         String
  enableAutoSync Boolean  @default(true)
  returnTo       String?
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model MicrosoftConnection {
  id                   String    @id @default(uuid())
  userId               String    @unique
  microsoftEmail       String?
  accessToken          String?
  refreshToken         String
  accessTokenExpiresAt DateTime?
  workbookDriveItemId  String?
  workbookDriveId      String?
  workbookWebUrl       String?
  workbookName         String?
  tableName            String    @default("Expenses")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReminderDelivery {
  id        String   @id @default(uuid())
  userId    String
  taskId    String
  sentAt    DateTime @default(now())
  chatId    String
  messageId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
  @@index([taskId, sentAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
}

model ProcessedTelegramUpdate {
  id        String   @id @default(uuid())
  updateId  Int      @unique
  createdAt DateTime @default(now())

  @@index([createdAt])
}
