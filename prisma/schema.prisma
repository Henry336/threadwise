generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  OPEN
  DONE
  CANCELED
}

enum IdeaStatus {
  RAW
  CLARIFIED
  SELECTED
  PROTOTYPING
  BUILT
  PAUSED
  REJECTED
}

enum ReminderMode {
  INDIVIDUAL
  DIGEST
}

enum CaptureKind {
  IDEA
  TASK
  REFLECTION
  NOTE
  NOISE
}

model User {
  id         String   @id @default(uuid())
  telegramId String   @unique
  username   String?
  firstName  String?
  lastName   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  settings          UserSettings?
  ideas             Idea[]
  tasks             Task[]
  notes             Note[]
  reflections       Reflection[]
  pendingCaptures   PendingCapture[]
  pendingNoteMerges PendingNoteMerge[]
  pendingItemEdits  PendingItemEdit[]
  pendingSearches   PendingSearch[]
  reminderHistory   ReminderDelivery[]
  auditLogs         AuditLog[]
}

model UserSettings {
  id                      String       @id @default(uuid())
  userId                  String       @unique
  reminderIntervalMinutes Int          @default(180)
  timezone                String       @default("Asia/Singapore")
  quietHoursStart         String?      @default("22:00")
  quietHoursEnd           String?      @default("08:00")
  maxRemindersPerDay      Int          @default(5)
  dueNudgeMinutes         Int          @default(3)
  reminderMode            ReminderMode @default(INDIVIDUAL)
  reminderChatId          String?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Idea {
  id             String     @id @default(uuid())
  userId         String
  publicId       String
  title          String
  concept        String
  problem        String?
  targetUser     String?
  type           String?
  status         IdeaStatus @default(RAW)
  tags           String[]
  sourceText     String
  embedding      Json?
  scores         Json?
  marketNotes    String?
  dos            String[]
  donts          String[]
  pinnedAt       DateTime?
  archivedAt     DateTime?
  archivedReason String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, publicId])
  @@index([userId, createdAt])
  @@index([userId, pinnedAt])
  @@index([userId, archivedAt])
}

model Task {
  id                      String     @id @default(uuid())
  userId                  String
  publicId                String
  title                   String
  description             String?
  status                  TaskStatus @default(OPEN)
  sourceText              String
  dueAt                   DateTime?
  timezone                String?
  reminderIntervalMinutes Int?
  nextReminderAt          DateTime?
  snoozedUntil            DateTime?
  completedAt             DateTime?
  lastRemindedAt          DateTime?
  reminderCount           Int        @default(0)
  embedding               Json?
  calendarUrl             String?
  pinnedAt                DateTime?
  archivedAt              DateTime?
  archivedReason          String?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminderHistory ReminderDelivery[]

  @@unique([userId, publicId])
  @@index([status, nextReminderAt])
  @@index([userId, createdAt])
  @@index([userId, pinnedAt])
  @@index([userId, archivedAt])
}

model Note {
  id               String    @id @default(uuid())
  userId           String
  publicId         String
  title            String
  body             String
  summary          String
  sourceText       String
  tags             String[]
  embedding        Json?
  pinnedAt         DateTime?
  archivedAt       DateTime?
  archivedReason   String?
  mergedIntoNoteId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  mergedIntoNote    Note?  @relation("NoteMerge", fields: [mergedIntoNoteId], references: [id], onDelete: SetNull)
  mergedSourceNotes Note[] @relation("NoteMerge")

  @@unique([userId, publicId])
  @@index([userId, createdAt])
  @@index([userId, pinnedAt])
  @@index([userId, archivedAt])
  @@index([userId, mergedIntoNoteId])
}

model Reflection {
  id              String    @id @default(uuid())
  userId          String
  publicId        String
  sourceText      String
  situation       String
  balancedView    String
  immediateAction String
  keepInMind      String
  risks           String[]
  embedding       Json?
  pinnedAt        DateTime?
  archivedAt      DateTime?
  archivedReason  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, publicId])
  @@index([userId, createdAt])
  @@index([userId, pinnedAt])
  @@index([userId, archivedAt])
}

model PendingCapture {
  id         String      @id @default(uuid())
  userId     String
  kind       CaptureKind
  sourceText String
  payload    Json
  expiresAt  DateTime
  createdAt  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PendingNoteMerge {
  id            String   @id @default(uuid())
  userId        String
  sourceNoteIds String[]
  preview       Json
  attemptCount  Int      @default(1)
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PendingItemEdit {
  id            String   @id @default(uuid())
  userId        String
  itemKind      String
  itemId        String
  itemPublicId  String
  editField     String   @default("title")
  previousTitle String
  previousValue String?
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PendingSearch {
  id          String   @id @default(uuid())
  userId      String
  query       String
  kinds       String[]
  label       String?
  includeDone Boolean  @default(false)
  doneOnly    Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model ReminderDelivery {
  id        String   @id @default(uuid())
  userId    String
  taskId    String
  sentAt    DateTime @default(now())
  chatId    String
  messageId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
  @@index([taskId, sentAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
}

model ProcessedTelegramUpdate {
  id        String   @id @default(uuid())
  updateId  Int      @unique
  createdAt DateTime @default(now())

  @@index([createdAt])
}
