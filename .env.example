# Required
TELEGRAM_BOT_TOKEN=
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/threadwise

# Optional for AI-assisted classification and synthesis features.
# Without this, Threadwise falls back to deterministic local heuristics.
OPENAI_API_KEY=

# Optional
OPENAI_MODEL=gpt-5.4-mini
# Comma-separated chat model fallback chain used after rate-limit or model availability errors.
# Put any preferred stronger model first, then cheaper/lower models after it.
OPENAI_MODEL_FALLBACKS=gpt-5.5,gpt-5.4,gpt-5.4-nano
# Enables private /admin/ai/status and /admin/reminders/* endpoints. Use a long random secret you create yourself.
# Send it as an Authorization Bearer token or x-threadwise-admin-token header.
ADMIN_STATUS_TOKEN=
# Optional. Overrides the production web dashboard opened by Telegram's persistent Dashboard button.
DASHBOARD_URL=https://threadwise-dashboard.vercel.app
PORT=3000
WEBHOOK_URL=
WEBHOOK_SECRET_PATH=/telegram/webhook
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Optional when WEBHOOK_URL is set; otherwise use https://YOUR_HOST/calendar/oauth/callback.
GOOGLE_CALENDAR_REDIRECT_URI=
# Recommended shared encryption key for Google tokens. Calendar falls back to GMAIL_TOKEN_ENCRYPTION_KEY for existing deployments.
GOOGLE_TOKEN_ENCRYPTION_KEY=
GMAIL_TOKEN_ENCRYPTION_KEY=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Optional when WEBHOOK_URL is set; otherwise use https://YOUR_HOST/excel/oauth/callback.
MICROSOFT_REDIRECT_URI=
# Use a long random secret. This encrypts each user's Microsoft OAuth tokens in the database.
MICROSOFT_TOKEN_ENCRYPTION_KEY=
GMAIL_SCAN_POLL_MS=900000
GMAIL_DAILY_SCAN_HOUR=8
GMAIL_MAX_UNREAD_PER_SCAN=10
REMINDER_POLL_MS=60000
DEFAULT_TIMEZONE=Asia/Singapore
DEFAULT_REMINDER_INTERVAL_MINUTES=180
DEFAULT_QUIET_HOURS_START=22:00
DEFAULT_QUIET_HOURS_END=08:00
BOT_ALLOWED_TELEGRAM_IDS=
