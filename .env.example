# Required
TELEGRAM_BOT_TOKEN=
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/threadwise

# Required for AI-powered classification, embeddings, scoring, and reflections.
# Without this, Threadwise falls back to deterministic local heuristics.
OPENAI_API_KEY=

# Optional
OPENAI_MODEL=gpt-5.4-mini
# Comma-separated chat model fallback chain used after rate-limit or model availability errors.
# Put any preferred stronger model first, then cheaper/lower models after it.
OPENAI_MODEL_FALLBACKS=gpt-5.5,gpt-5.4,gpt-5.4-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Enables private /admin/ai/status and /admin/reminders/* endpoints. Use a long random secret you create yourself.
# Send it as an Authorization Bearer token or x-threadwise-admin-token header.
ADMIN_STATUS_TOKEN=
PORT=3000
WEBHOOK_URL=
WEBHOOK_SECRET_PATH=/telegram/webhook
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GMAIL_TOKEN_ENCRYPTION_KEY=
GMAIL_SCAN_POLL_MS=900000
GMAIL_DAILY_SCAN_HOUR=8
GMAIL_MAX_UNREAD_PER_SCAN=10
REMINDER_POLL_MS=60000
DEFAULT_TIMEZONE=Asia/Singapore
DEFAULT_REMINDER_INTERVAL_MINUTES=180
DEFAULT_QUIET_HOURS_START=22:00
DEFAULT_QUIET_HOURS_END=08:00
BOT_ALLOWED_TELEGRAM_IDS=
