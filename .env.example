# Required
TELEGRAM_BOT_TOKEN=
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/threadwise

# Required for AI-powered classification, embeddings, scoring, and reflections.
# Without this, Threadwise falls back to deterministic local heuristics.
OPENAI_API_KEY=

# Optional
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
PORT=3000
WEBHOOK_URL=
WEBHOOK_SECRET_PATH=/telegram/webhook
REMINDER_POLL_MS=60000
DEFAULT_TIMEZONE=Asia/Singapore
DEFAULT_REMINDER_INTERVAL_MINUTES=180
DEFAULT_QUIET_HOURS_START=22:00
DEFAULT_QUIET_HOURS_END=08:00
BOT_ALLOWED_TELEGRAM_IDS=
