{
  "name": "threadwise",
  "version": "0.13.0",
  "description": "A Telegram life inbox for notes, tasks, reminders, local image OCR, expenses, Excel sync, search, and ideas.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "smoke:ocr": "tsx scripts/ocr-smoke.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:dev": "prisma migrate dev"
  },
  "keywords": [
    "telegram",
    "bot",
    "productivity",
    "reminders",
    "ideas"
  ],
  "author": "Henry336",
  "license": "MIT",
  "overrides": {
    "uuid": "11.1.1"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@tesseract.js-data/eng": "^1.0.0",
    "@tesseract.js-data/mya": "^1.0.0",
    "exceljs": "^4.4.0",
    "fastify": "^5.1.0",
    "grammy": "^1.33.0",
    "luxon": "^3.5.0",
    "openai": "^4.76.0",
    "sharp": "^0.35.3",
    "tesseract.js": "^7.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.10.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
